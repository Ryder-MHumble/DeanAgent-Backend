# RSSHub (self-hosted or public instance)
RSSHUB_BASE_URL=https://rsshub.app

# Playwright
PLAYWRIGHT_MAX_CONTEXTS=3

# Scheduler / Crawler
MAX_CONCURRENT_CRAWLS=5
DEFAULT_REQUEST_DELAY=1.0

# Database backend (recommended: local PostgreSQL)
DB_BACKEND=postgres
POSTGRES_DSN=
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=zgci_db

# Daily pipeline schedule (UTC)
PIPELINE_CRON_HOUR=6
PIPELINE_CRON_MINUTE=0
POLICY_REFRESH_INTERVAL_HOURS=4

# LLM enrichment in daily pipeline (auto-enabled when at least one provider key is set)
ENABLE_LLM_ENRICHMENT=true
LLM_THRESHOLD=40

# Auto-trigger pipeline on first start if no data exists
STARTUP_CRAWL_ENABLED=true

# Social media cookies (optional)
WEIBO_COOKIE=
XIAOHONGSHU_COOKIE=

# API auth (optional simple key for frontend)
API_KEY=

# OpenRouter LLM (for policy/personnel LLM enrichment)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions

# SiliconFlow LLM (fallback provider)
SILICONFLOW_API_KEY=
SILICONFLOW_MODEL=Pro/moonshotai/Kimi-K2.6
SILICONFLOW_API_URL=https://api.siliconflow.cn/v1/chat/completions

# Twitter API (twitterapi.io) - for KOL monitoring & social search
TWITTER_API_KEY=
TWITTER_API_PROXY=http://127.0.0.1:7890
